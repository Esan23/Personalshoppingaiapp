# Trine environment variables
# Copy to `.env` for local dev (`netlify dev`) and set the same in Netlify UI.

# --- Client (exposed to the browser; safe — anon key is RLS-guarded) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server (Netlify function only; NEVER prefixed with VITE_) ---
# Without this, the curate function returns an illustrative demo shortlist.
ANTHROPIC_API_KEY=

# --- Retailer feeds (optional). With these, /app returns REAL listings ---
# ranked by Claude instead of AI-generated picks with search links.
# eBay: either a static Browse token, OR client id/secret (auto-minted, preferred).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ACCESS_TOKEN=
# Best Buy: a free Developer API key.
BESTBUY_API_KEY=

# --- Scraped retailers via Firecrawl (optional, paid per request) ---
# When set, /app also pulls Amazon, The RealReal, and Nordstrom by scraping
# their search pages (they have no usable free product API). Get a key at
# https://www.firecrawl.dev. Scraping is slower than the APIs above; each call
# is hard-capped by SCRAPE_TIMEOUT_MS and uses Firecrawl's cache for fast,
# free repeat queries.
FIRECRAWL_API_KEY=
# Per-scrape time budget in ms (default 8000). Keep the total under the Netlify
# function timeout (~10s) so a slow scrape never breaks the core results.
SCRAPE_TIMEOUT_MS=8000
